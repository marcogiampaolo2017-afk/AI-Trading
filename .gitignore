# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
ENV/
env.bak/
venv.bak/

# ── Secrets — NEVER commit credentials ────────────────────────────────────────
.env
*.env
.env.*
secrets.py

# ── Training artifacts (generated, large, not version-controlled) ─────────────
models/*.zip
models/*.pkl
models/best_models/
models/checkpoints/
tensorboard_logs/
tensorboard_log/
logs/
best_models/

# ── Brain memory (runtime state, regenerated each session) ────────────────────
brain_memory/*.pkl
brain_memory/*.json
brain_memory/*.csv

# ── Reports (generated by train/test scripts) ─────────────────────────────────
reports/*.png
reports/*.csv
reports/*.txt

# ── Data files (large CSVs — distribute separately) ──────────────────────────
data/*.csv

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
log_horita.txt
stop_training.flag
*.bak
*.bak_old
.DS_Store
Thumbs.db
